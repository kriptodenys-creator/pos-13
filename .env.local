# Telegram Bot Configuration

# Отримайте токен бота у @BotFather в Telegram

TELEGRAM_BOT_TOKEN=your_bot_token_here



# ID чату для отримання повідомлень

# Отримайте ваш chat_id у @userinfobot в Telegram

TELEGRAM_CHAT_ID=your_chat_id_here



# USB термопринтер (Windows)

PRINTER_NAME=POS58
PRINTER_ENCODING=us-ascii
PRINTER_FORCE_LATIN=1
DAILY_STATS_PRINT_ENABLED=1


# Оптимізація продуктивності

NEXT_TELEMETRY_DISABLED=1

NODE_OPTIONS=--max-old-space-size=4096
